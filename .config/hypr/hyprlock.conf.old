source = $HOME/.config/hypr/colors.conf

background {
    monitor =
    path = $HOME/.config/hypr/lockscreen.png

    blur_size = 5
    blur_passes = 3
    noise = 0.0117
    contrast = 1.3
    brightness = 0.8
    vibrancy = 0.21
    vibrancy_darkness = 0.0
}

# ── Hour ──────────────────────────────────────────
label {
    monitor =
    text = cmd[update:1000] echo "<b> $(date +"%H") </b>"
    color = rgba(255, 255, 255, 0.95)
    font_size = 120
    font_family = IBM Plex Sans Medium
    shadow_passes = 2
    shadow_size = 10
    shadow_color = rgba(0, 0, 0, 0.4)
    position = 0, 130
    halign = center
    valign = center
}

# ── Minute ────────────────────────────────────────
label {
    monitor =
    text = cmd[update:1000] echo "<b> $(date +"%M") </b>"
    color = rgba(255, 255, 255, 0.95)
    font_size = 120
    font_family = IBM Plex Sans Medium
    shadow_passes = 2
    shadow_size = 10
    shadow_color = rgba(0, 0, 0, 0.4)
    position = 0, -10
    halign = center
    valign = center
}

# ── Day name ──────────────────────────────────────
label {
    monitor =
    text = cmd[update:60000] echo "$(date +"%A")"
    color = $secondary
    font_size = 16
    font_family = IBM Plex Sans Medium
    position = 0, -155
    halign = center
    valign = center
}

# ── Date ──────────────────────────────────────────
label {
    monitor =
    text = cmd[update:60000] echo "$(date +"%d %B")"
    color = $secondary
    font_size = 14
    font_family = IBM Plex Sans
    position = 0, -178
    halign = center
    valign = center
}

# ── Password input ────────────────────────────────
input-field {
    monitor =
    size = 250, 50
    outline_thickness = 3
    dots_size = 0.2
    dots_spacing = 1.0
    dots_center = true
    rounding = 22
    outer_color = $source_color
    inner_color = rgba(255, 255, 255, 0.1)
    font_color = $on_surface
    font_family = IBM Plex Sans
    fade_on_empty = true
    placeholder_text = <i>Password...</i>
    fail_color = $error
    fail_text = <i>$ATTEMPTS remaining</i>
    fail_transition = 300
    position = 0, 60
    halign = center
    valign = bottom
}
